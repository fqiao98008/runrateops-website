# Copy this file to .env.local and fill in your values
# Never commit .env.local to git

# Your site's public URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://runrateops.com

# Optional: Formspree endpoint for the contact form
# Sign up at https://formspree.io, create a form, paste the endpoint here
NEXT_PUBLIC_FORMSPREE_URL=https://formspree.io/f/YOUR_FORM_ID

# Google Analytics 4 Measurement ID
# Get it from: analytics.google.com → Admin → Data Streams → your stream
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
